void drawCancelledMessage() {
  u8g2.clearBuffer();
  u8g2.setFont(u8g2_font_6x13_tr);
  u8g2.drawStr(30, 30, "Cancelled!");
  u8g2.sendBuffer();
}

void restartDevice() {
  u8g2.clearBuffer();
  u8g2.setFont(u8g2_font_6x13_tr);
  u8g2.drawStr(30, 30, "Restarting...");
  u8g2.sendBuffer();
  delay(1000);
  ESP.restart();
}
