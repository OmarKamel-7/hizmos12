void restartesp() {
  
  if (digitalRead(BTN_SELECT) == LOW) {
    delay(200);
    restartDevice();
  }

  
  if (digitalRead(BTN_BACK) == LOW) {
    delay(200);
    drawCancelledMessage();
    while (1); 
  }
}

